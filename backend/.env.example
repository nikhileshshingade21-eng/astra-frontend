# ASTRA Backend Configuration

# Railway Backend URL (Node.js backend)
RAILWAY_BACKEND_URL=https://astra-backend-production-e996.up.railway.app

# Firebase Cloud Messaging (for push notifications)
# Download your Firebase service account JSON and place it in /app/backend/firebase-credentials.json
FIREBASE_CREDENTIALS_PATH=/app/backend/firebase-credentials.json

# Optional: MongoDB (if using local database)
# MONGO_URL=mongodb://localhost:27017
# DB_NAME=astra_db

# CORS Origins (comma-separated)
CORS_ORIGINS=*
